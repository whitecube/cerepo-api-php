{
  "name": "whitecube/cerepo-php",
  "description": "PHP client wrapper for the CeRepo Central Repository API (Infosanté & partners).",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Whitecube",
      "homepage": "https://whitecube.be"
    }
  ],
  "require": {
    "php": "^8.1.0",
    "guzzlehttp/guzzle": "^7.10",
    "psr/http-message": "^1.0 || ^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "symfony/var-dumper": "^6.0 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "Whitecube\\Cerepo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Whitecube\\Cerepo\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
